# ─── API Keys ────────────────────────────────────────────
# API keys can also be set per-model in ~/.config/rust_agent/models.toml
# Environment variables here serve as a fallback.

# Anthropic API Key (required for Anthropic provider)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (required for OpenAI provider)
# OPENAI_API_KEY=sk-xxxxx

# Custom LLM API Key (for compatible providers)
# LLM_API_KEY=your-key-here

# ─── Model Selection (legacy) ───────────────────────────
# These are still supported but prefer using ~/.config/rust_agent/models.toml
# for multi-model management. See /model command in the agent.

# Custom LLM model (overrides default or CLI if set)
# LLM_MODEL=claude-sonnet-4-20250514

# Custom LLM provider: anthropic (default), openai, compatible
# LLM_PROVIDER=anthropic

# Custom base URL (for self-hosted or compatible APIs)
# LLM_BASE_URL=http://localhost:8080

